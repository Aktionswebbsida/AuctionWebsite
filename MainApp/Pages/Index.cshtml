<section class="py-5 bg-dark">
    <div class="container px-4 px-lg-5 mt-5">
        <h1 class="text-center text-white">Popular Auctions</h1>
        <a class="btn btn-primary mb-3" asp-page="/Seller/AdCreate">Create Ad</a>
        
        <div id="AdCarousel" class="carousel slide" data-bs-ride="carousel">
            <div class="carousel-inner">
                @{
                    var first = true;
                }
                @if (Model.Ads != null && Model.Ads.Any())
                {
                    foreach (var ad in Model.Ads)
                    {
                        <div class="carousel-item @(first ? "active" : "")">
                           
                            <div class="row justify-content-center">
                                <div class="col-sm-8 col-md-6 col-lg-4 mb-5">
                                    <div class="card h-100">
                                        <!-- Product image-->
                                        <img class="card-img-top" src="@(ad.Images?.FirstOrDefault()?.Url ?? "https://dummyimage.com/450x300/dee2e6/6c757d.jpg")" alt="Ad Image" style="height: 250px; object-fit: cover;" />
                                        
                                        <!-- Product details-->
                                        <div class="card-body p-4">
                                            <div class="text-center">
                                                <!-- Product name-->
                                                <h5 class="fw-bolder">@ad.Title</h5>
                                                <p class="text-muted small">@ad.Place</p>
                                                <!-- Product price-->
                                                <div class="fs-5 fw-bold">$@ad.StartingPrice</div>
                                            </div>
                                        </div>
                                        
                                        <!-- Product actions-->
                                        <div class="card-footer p-4 pt-0 border-top-0 bg-transparent">
                                            <div class="text-center">
                                                <a class="btn btn-outline-dark w-100 mt-auto" asp-route-Id="@ad.AdID" asp-page="/Shared/ShopItemDetails">View Details</a>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        first = false;
                    }
                }
                else
                {
                    <div class="carousel-item active">
                        <div class="text-center text-white py-5">
                            <h2>No Ads Available</h2>
                        </div>
                    </div>
                }
            </div>

       
            @if (Model.Ads?.Count() > 1)
            {
                <button class="carousel-control-prev" type="button" data-bs-target="#AdCarousel" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon bg-dark rounded-circle p-3" aria-hidden="true"></span>
                    <span class="visually-hidden">Previous</span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#AdCarousel" data-bs-slide="next">
                    <span class="carousel-control-next-icon bg-dark rounded-circle p-3" aria-hidden="true"></span>
                    <span class="visually-hidden">Next</span>
                </button>
            }
        </div>
    </div>
</section>
